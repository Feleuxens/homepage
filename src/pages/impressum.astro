            <!-- English Content -->
            <div class="tab-content" id="english-content">
                <div class="text-sm text-gray-500 text-center mb-12">Legal Notice</div>

                <div class="prose prose-lg max-w-none">
                    <!-- Service Provider Information -->
                    <section class="legal-section">
                        <h2 class="legal-heading">Content provider</h2>
                        <div class="legal-content">
                            <p><strong>Felix Grüb</strong></p>
                            <p>Sielminger Hauptstraße 69/2<br>
                                70794 Filderstadt<br>
                                Germany</p>
                        </div>
                    </section>

                    <!-- Contact -->
                    <section class="legal-section">
                        <h2 class="legal-heading">Contact</h2>
                        <div class="legal-content">
                            <p><strong>E-Mail:</strong> me@feleuxens.de<br>
                                <strong>Phone:</strong> +491789056536</p>
                        </div>
                    </section>

                    <!-- VAT ID -->
