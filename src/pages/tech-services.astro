    <section class="py-12 bg-primary text-white">
        <div class="container text-center">
            <h2 class="text-3xl md:text-4xl font-serif font-bold mb-6">Ready to Transform Your Infrastructure?</h2>
            <p class="text-xl mb-10 max-w-2xl mx-auto text-white/90">
                Let's discuss how modern DevOps practices can accelerate your business growth and improve your system reliability.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="/contact" class="btn white">Get Started Today</a>
                <a href="/about" class="btn white-transparent">Learn More About Me</a>
            </div>
        </div>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Register GSAP plugins
            gsap.registerPlugin(ScrollTrigger);

            // Hero animations
            gsap.to('#hero-title', { opacity: 1, y: 0, duration: 1, ease: 'power3.out' });
            gsap.to('#hero-subtitle', { opacity: 1, y: 0, duration: 1, delay: 0.3, ease: 'power3.out' });
            gsap.to('#hero-buttons', { opacity: 1, y: 0, duration: 1, delay: 0.6, ease: 'power3.out' });

            // Service cards animation
            gsap.from('.service-card', {
                scrollTrigger: {
                    trigger: '.service-card',
                    start: 'top 80%',
                },
                y: 50,
                opacity: 0,
                duration: 0.8,
                stagger: 0.2,
                ease: 'power2.out'
            });

            // Technology progress bars
            gsap.from('.tech-item', {
                scrollTrigger: {
                    trigger: '.tech-item',
                    start: 'top 80%',
                },
                opacity: 0,
                x: -20,
                duration: 0.6,
                stagger: 0.1,
                ease: 'power2.out'
            });

            // Animate progress bars
            const progressBars = document.querySelectorAll('.tech-progress');
            progressBars.forEach(bar => {
                const level = bar.getAttribute('data-level');
                gsap.to(bar, {
                    scrollTrigger: {
                        trigger: bar,
                        start: 'top 80%',
                    },
                    width: `${level}%`,
                    duration: 1.5,
                    ease: 'power2.out'
                });
            });

            // Process items animation
            gsap.from('.process-item', {
                scrollTrigger: {
                    trigger: '.process-item',
                    start: 'top 80%',
                },
                y: 30,
                opacity: 0,
                duration: 0.8,
                stagger: 0.2,
                ease: 'power2.out'
            });
        });
    </script>
</MainLayout>