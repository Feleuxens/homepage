---
import MainLayout from '../layouts/MainLayout.astro';
import "../styles/about.css";
import { Image } from "astro:assets";
import meImg from "../../public/images/me.jpg";

const technicalSkills = [
  { name: "Linux/System Administration", level: 80 },
  { name: "Docker/Docker Compose", level: 70 },
  { name: "Python", level: 75 },
  { name: "Java", level: 60 },
  { name: "Kubernetes", level: 50 },
  { name: "Terraform", level: 50},
  { name: "Gitlab CI", level: 75},
  { name: "OPNsense", level: 60},
  { name: "Software Architecture", level: 35}
];

const timeline: object = [
  {
    startYear: 2023,
    endYear: "present",
    title: "Working Student for DevOps and Software Development",
    company: "intension GmbH",
    description: "",
    type: "tech"
  },
  {
    startYear: 2020,
    endYear: 2024,
    title: "Bachelor's Degree in Computer Science",
    company: "University of Stuttgart",
    description: "",
    type: "tech"
  },
  {
    startYear: 2025,
    endYear: 2025,
    title: "Certified Professional for Software Architecture - Foundation Level",
    company: "iSAQB",
    description: "Basic Concepts of Software Architecture, Requirements and Constraints, Design and Development, etc.",
    type: "tech"
  },
  {
    startYear: 2020,
    endYear: 2020,
    title: "Music exam in A-levels",
    company: "",
    description: "Played Clarke Suit in D Major (Bourrée, Ecossaise, Prince of Denmark's March), Rachmaninoff Prelude in C# minor and Neruda Trumpet Concerto in E♭ Major: I. Allegro",
    type: "music"
  },
  {
    startYear: 2008,
    endYear: 2020,
    title: "Trumpet lessons",
    company: "",
    description: "",
    type: "music"
  },
  {
    startYear: 2016,
    endYear: 2023,
    title: "Piano lessons",
    company: "",
    description: "",
    type: "music"
  },
];

// Set current year for "present" calculations
const currentYear = new Date().getFullYear();

// Helper function to get actual end year
function getEndYear(endYear) {
  return endYear === "present" ? currentYear : endYear;
}

// Get timeline range from all years (both start and end)
const allYears = timeline.flatMap(item => [item.startYear, getEndYear(item.endYear)]);
const timelineStartYear = 2002; // Math.min(...allYears);
const timelineEndYear = Math.max(...allYears);

// Fixed timeline height in pixels
const TIMELINE_HEIGHT = 1000;

// Function to calculate position percentage for a given year
function getYearPosition(year) {
  const progress = (timelineEndYear - year) / (timelineEndYear - timelineStartYear);
  return progress * 100;
}

function estimateCardHeight(item) {
  // Base height for title, company, and year badge (in percentage of timeline)
  let baseHeight = 8;

  if (item.description && item.description.length > 0) {
    const descriptionLines = Math.ceil(item.description.length / 50);
    baseHeight += Math.min(descriptionLines * 3, 6.5);
  }

  // Add height for long company names
  if (item.company && item.company.length > 0) {
    baseHeight += 1;
  }

  // Add height for long titles
  if (item.title && item.title.length > 40) {
    baseHeight += 2;
  }

  return baseHeight;
}

// Function to position items based on end year with overlap prevention
function positionTimelineItems(items) {
  // Sort by end year (descending)
  const sortedItems = [...items].sort((a, b) =>
      getEndYear(b.endYear) - getEndYear(a.endYear)
  );

  const cardSpacingPercent = 2; // Minimum gap as percentage
  const usedPositions = [];

  sortedItems.forEach(item => {
    // Calculate this card's estimated height
    const cardHeight = estimateCardHeight(item);

    // Get the exact position that matches year markers
    const endYear = getEndYear(item.endYear);
    let position = getYearPosition(endYear);

    // Check for overlaps and adjust card position if needed
    let hasOverlap = true;
    let attempts = 0;

    while (hasOverlap && attempts < 10) {
      hasOverlap = false;
      attempts++;

      for (const usedPos of usedPositions) {
        const usedHeight = usedPos.height;
        const usedTop = usedPos.position;
        const usedBottom = usedTop + usedHeight;

        const currentTop = position;
        const currentBottom = position + cardHeight;

        // Check if cards overlap (with spacing buffer)
        if (currentTop < (usedBottom + cardSpacingPercent) &&
            currentBottom > (usedTop - cardSpacingPercent)) {
          // Overlap detected, move card below the overlapping card
          position = usedBottom + cardSpacingPercent;
          hasOverlap = true;
          break;
        }
      }
    }

    // Store both the year-aligned position (for dot) and adjusted position (for card)
    item.dotPosition = getYearPosition(endYear);
    item.cardPosition = position;
    item.estimatedHeight = cardHeight;

    // Track this card's position and dimensions for future overlap checks
    usedPositions.push({
      item: item,
      position: position,
      height: cardHeight
    });
  });

  return sortedItems;
}

// Separate and position tech and music items
const techItems = timeline.filter(item => item.type === "tech");
const musicItems = timeline.filter(item => item.type === "music");

const positionedTechItems = positionTimelineItems(techItems);
const positionedMusicItems = positionTimelineItems(musicItems);

// Generate year markers
const yearMarkers = [];
for (let year = timelineEndYear; year >= timelineStartYear; year--) {
  yearMarkers.push({
    year,
    position: getYearPosition(year)
  });
}

// Track which years have dots for each side
const techDotYears = new Set(techItems.map(item => getEndYear(item.endYear)));
const musicDotYears = new Set(musicItems.map(item => getEndYear(item.endYear)));
---

<MainLayout title="About Me">
  <section class="bg-gray-100 pt-24 pb-8">
    <div class="container">
      <h1 class="section-title text-center mb-12" id="about-title">About Me</h1>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
        <div class="about-image justify-self-center">
          <Image src={meImg} alt="Felix" class="profile-photo" width="500" height="500" />
        </div>

        <div class="about-content space-y-6">
          <h2 class="text-3xl animate-item">Hello, I'm Felix</h2>

          <p class="text-gray-700 animate-item">
            I'm Felix, a computer science student specializing in IT-security and distributed systems.
            When I'm not diving into system administration or exploring IT security, you'll find me at the piano or
            capturing moments through my camera lens. I love how technical precision and creative expression complement
            each other—whether debugging infrastructure or perfecting a Rachmaninoff prelude. Want to see how these
            passions have shaped my path? Keep scrolling.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 animate-item">
            <a href="/contact" class="btn secondary">Contact Me</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section class="py-12 bg-white">
    <div class="container">
      <h2 class="section-title text-center">My Skills</h2>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 mt-12">
        <!-- Technical Skills -->
        <div class="skills-category">
          <h3 class="text-2xl mb-8 text-center">Technical Skills</h3>

          <div class="space-y-6">
            {technicalSkills.map(skill => (
                <div class="skill-item">
                  <div class="flex justify-between mb-2">
                    <span class="font-medium">{skill.name}</span>
                    <span class="text-gray-500">{skill.level}%</span>
                  </div>
                  <div class="h-2 bg-gray-200 rounded-full overflow-hidden">
                    <div
                        class="skill-progress bg-primary h-full rounded-full"
                        data-level={skill.level}
                    ></div>
                  </div>
                </div>
            ))}
          </div>
        </div>

        <!-- Musical Skills -->
        <div class="skills-category">
          <h3 class="text-2xl mb-8 text-center">Musical Background</h3>

          <div class="space-y-6">
            <!-- Piano Card -->
            <div class="instrument-card group">
              <div class="instrument-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M6 19h12a2 2 0 002-2V7a2 2 0 00-2-2H6a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  <path d="M8 7v10M12 7v10M16 7v10"/>
                  <path d="M6 11h12"/>
                </svg>
              </div>

              <div class="instrument-content">
                <div class="instrument-header">
                  <h4 class="instrument-name">Piano</h4>
                  <span class="instrument-years">from 2016</span>
                </div>

                <p class="instrument-description">
                  Classical and contemporary repertoire with focus on performance and music theory
                </p>
                <div class="instrument-highlight">
                  <strong>Pieces:</strong> Rachmaninoff - Prelude in C# Minor,<br>
                  Rachmaninoff - Prelude G# Minor,<br>
                  Schubert - 4 Impromptus, Op. 90, D. 899: No. 2 in E♭ Major
                </div>

                <div class="instrument-specialties">
                  <span class="specialty-tag">Classical</span>
                  <span class="specialty-tag">Contemporary</span>
                  <span class="specialty-tag">Performance</span>
                </div>
              </div>
            </div>

            <!-- Trumpet Card -->
            <div class="instrument-card group">
              <div class="instrument-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 12h6l2 2v4l-2 2H9l-2-2v-4l2-2z"/>
                  <path d="M7 12H3a1 1 0 01-1-1V9a1 1 0 011-1h4"/>
                  <circle cx="15" cy="12" r="1"/>
                  <circle cx="18" cy="12" r="1"/>
                  <circle cx="21" cy="12" r="1"/>
                </svg>
              </div>

              <div class="instrument-content">
                <div class="instrument-header">
                  <h4 class="instrument-name">Trumpet</h4>
                  <span class="instrument-years">from 2008</span>
                </div>

                <p class="instrument-description">
                  Classical trumpet in multiple orchestras as well as solo performances and competitions.
                </p>
                <div class="instrument-highlight">
                  <strong>Pieces:</strong> Neruda - Trumpet Concerto in E♭ major: I. Allegro,<br>
                  Bach - Weihnachtsoratorium: Großer Herr und starker König,<br>
                  Albinoni - Concerto in B♭, Op.7 Nr.3: I. Allegro
                </div>

                <div class="instrument-specialties">
                  <span class="specialty-tag">Classical</span>
                  <span class="specialty-tag">Competitions</span>
                  <span class="specialty-tag">Performance</span>
                </div>
              </div>
            </div>

            <!-- Music Theory & General Skills Card -->
            <div class="instrument-card group">
              <div class="instrument-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 18V5l12-2v13"/>
                  <circle cx="7" cy="18" r="2" fill="currentColor"/>
                  <circle cx="19" cy="16.5" r="2" fill="currentColor"/>
                  <path d="M17 7 L 20 6.5"/>
                  <circle cx="12.5" cy="16" r="0.5" fill="currentColor" />
                </svg>
              </div>

              <div class="instrument-content">
                <div class="instrument-header">
                  <h4 class="instrument-name">Music Theory & Skills</h4>
                  <span class="instrument-years">from 2008</span>
                </div>

                <p class="instrument-description">
                  Comprehensive understanding of music theory, composition, and arrangement.
                </p>

                <div class="instrument-specialties">
                  <span class="specialty-tag">Theory</span>
                  <span class="specialty-tag">Sight Reading</span>
                  <span class="specialty-tag">Arrangement</span>
                  <span class="specialty-tag">Transcription</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline Section -->
  <section class="py-12 bg-gray-100">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl text-center mb-12">My Journey</h2>

      <!-- Timeline -->
      <div class="relative">
        <!-- Center line -->
        <div class="absolute left-1/2 transform -translate-x-1/2 w-1 bg-gray-300" style={`height: calc(${TIMELINE_HEIGHT}px + 25px);`}></div>

        <!-- Year markers -->
        <div class="hidden md:block">
          {yearMarkers.map(({ year, position }) => (
              <div class="absolute left-1/2 transform -translate-x-20 flex items-center"
                   style={`top: calc(${position}%);`}>
                <div class="text-sm font-medium text-gray-600">{year}</div>
                <div class="w-6 h-px bg-gray-400 ml-2"></div>
              </div>
          ))}
        </div>

        <!-- Timeline items container -->
        <div class="relative" style={`height: ${TIMELINE_HEIGHT}px;`}>
          <!-- Dots for unique years on tech side -->
          {Array.from(techDotYears).map(year => (
              <div class="absolute right-1/2 transform translate-x-0.5 w-4 h-4 rounded-full bg-primary border-2 border-white shadow-md hidden md:block z-20"
                   style={`top: calc(${getYearPosition(year)}% + 1px); margin-right: -6px;`}></div>
          ))}

          <!-- Dots for unique years on music side -->
          {Array.from(musicDotYears).map(year => (
              <div class="absolute left-1/2 transform -translate-x-0.5 w-4 h-4 rounded-full bg-secondary border-2 border-white shadow-md hidden md:block z-20"
                   style={`top: calc(${getYearPosition(year)}% + 1px); margin-left: -6px;`}></div>
          ))}

          <!-- Tech Items (Left) -->
          {positionedTechItems.map(item => (
              <div class="absolute left-0 md:w-[calc(50%-30px)] w-full timeline-item tech-item" style={`top: ${item.cardPosition}%;`}>
                <div class="relative pr-8 md:pr-16">
                  <!-- Connector line to the shared dot -->
                  {item.dotPosition !== item.cardPosition && (
                      <>
                        <!-- Vertical connector from card to dot level -->
                        <div class="absolute right-[7px] bg-primary/40 w-0.5 hidden md:block"
                             style={`
                           top: 40px;
                           height: calc(${Math.abs(item.dotPosition - item.cardPosition)}% * ${TIMELINE_HEIGHT}px / 100 - 8px);
                           ${item.dotPosition < item.cardPosition ? `transform: translateY(calc(${item.dotPosition - item.cardPosition}% * ${TIMELINE_HEIGHT}px / 100 + 8px));` : ''}
                         `}></div>
                      </>
                  )}

                  <!-- Card -->
                  <div class="card bg-white rounded-lg shadow-md p-4 border-l-4 border-primary hover:shadow-lg transition-shadow">
                    <div class="flex justify-between items-center mb-3">
                      <div class="px-3 py-1 text-sm font-medium bg-primary/10 text-primary rounded-full">
                        {item.startYear === item.endYear && (
                            item.startYear
                        )}
                        {item.startYear !== item.endYear && (
                            item.startYear + " - " + item.endYear
                        )}
                      </div>

                      {item.endYear === "present" && (
                          <span class="text-xs px-2 py-1 bg-green-100 text-green-800 rounded-full">
                        Current
                      </span>
                      )}
                      {(item.endYear !== item.startYear && item.endYear !== "present") && (
                          <span class="text-xs text-gray-500">
                          {item.endYear - item.startYear} years
                        </span>
                      )}
                    </div>

                    <h3 class="text-xl">{item.title}</h3>
                    {item.company && <p class="text-gray-600 font-medium text-sm mt-1">{item.company}</p>}
                    {item.description && <p class="text-gray-700 mt-2">{item.description}</p>}
                  </div>
                </div>
              </div>
          ))}

          <!-- Music Items (Right) -->
          {positionedMusicItems.map(item => (
              <div class="absolute right-0 md:w-[calc(50%-30px)] w-full timeline-item music-item" style={`top: ${item.cardPosition}%;`}>
                <div class="relative pl-8 md:pl-16">
                  <!-- Connector line to the shared dot -->
                  {item.dotPosition !== item.cardPosition && (
                        <!-- Vertical connector from card to dot level -->
                        <div class="absolute left-[7px] bg-secondary/40 w-0.5 hidden md:block"
                             style={`
                           top: 40px;
                           height: calc(${Math.abs(item.dotPosition - item.cardPosition)}% * ${TIMELINE_HEIGHT}px / 100 - 8px);
                           ${item.dotPosition < item.cardPosition ? `transform: translateY(calc(${item.dotPosition - item.cardPosition}% * ${TIMELINE_HEIGHT}px / 100 + 8px));` : ''}
                         `}></div>
                  )}

                  <!-- Card -->
                  <div class="card bg-white rounded-lg shadow-md p-4 border-l-4 border-secondary hover:shadow-lg transition-shadow">
                    <div class="flex justify-between items-center mb-3">
                      <div class="px-3 py-1 text-sm font-medium bg-secondary/10 text-secondary rounded-full">
                        {item.startYear === item.endYear && (
                            item.startYear
                        )}
                        {item.startYear !== item.endYear && (
                            item.startYear + " - " + item.endYear
                        )}
                      </div>

                      {item.endYear === "present" && (
                          <span class="text-xs px-2 py-1 bg-green-100 text-green-800 rounded-full">
                        Current
                      </span>
                      )}
                      {(item.endYear !== item.startYear && item.endYear !== "present") && (
                          <span class="text-xs text-gray-500">
                          {item.endYear - item.startYear} years
                        </span>
                      )}
                    </div>

                    <h3 class="text-xl">{item.title}</h3>
                    {item.company && <p class="text-gray-600 font-medium text-sm mt-1">{item.company}</p>}
                    {item.description && <p class="text-gray-700 mt-2">{item.description}</p>}
                  </div>
                </div>
              </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Personal Interests -->
  <section class="py-12 bg-white">
    <div class="container">
      <h2 class="section-title text-center">Personal Interests</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12 interests-items">
        <div class="card p-6 text-center interests-item">
          <div class="w-16 h-16 mx-auto mb-4 text-primary">
            <svg viewBox="0 0 550 550" fill="currentColor" stroke="currentColor" stroke-width="10" stroke-linecap="round" stroke-linejoin="round">
              <path d="m503.306 111.184-.883-.883c-11.476-11.476-31.779-11.476-43.255 0l-45.903 46.786c-2.648 2.648-6.179 2.648-8.828 0L339.995 97.06c-6.179-5.297-14.124-8.828-22.952-8.828h-96.221c-2.648 0-4.414.883-5.297 1.766l-81.214 77.683c-11.476 12.359-12.359 31.779-1.766 43.255 5.297 6.179 13.241 9.71 22.069 9.71s16.772-3.531 22.069-9.71l57.379-60.91h20.303L120.188 300.094H37.209c-20.303 0-36.193 15.007-37.076 33.545-.883 9.71 2.648 19.421 9.71 26.483 7.062 6.179 15.89 10.593 25.6 10.593H159.03c2.648 0 4.414-.883 6.179-2.648l63.559-67.972 52.965 55.614-15.89 102.4c-4.414 17.655 4.414 34.428 19.421 41.49 5.297 2.648 9.71 3.531 15.007 3.531s10.593-.883 15.89-3.531c8.828-4.414 15.89-13.241 18.538-23.835l27.365-147.421c0-2.648-.883-6.179-2.648-7.945l-73.269-73.269 58.262-58.262 40.607 40.607c11.476 11.476 30.897 11.476 42.372 0l75.917-75.917c11.477-11.477 11.477-30.897.001-42.373m-12.359 30.014-75.917 75.917c-5.297 4.414-13.241 4.414-17.655 0l-46.786-46.786c-3.531-3.531-8.828-3.531-12.359 0l-70.621 70.621c-1.766 1.766-2.648 3.531-2.648 6.179s.883 4.414 3.531 7.062l75.917 75.917-26.483 142.124c-1.766 4.414-5.297 8.828-9.71 11.476-4.414 1.766-9.71 2.648-15.007 0-7.945-3.531-11.476-12.359-9.71-22.069l16.772-107.697c0-2.648-.883-5.297-2.648-7.062l-62.676-65.324c-1.766-1.766-3.531-2.648-6.179-2.648s-5.297.883-6.179 2.648l-67.09 71.503H35.444q-7.945 0-13.241-5.297c-2.648-3.531-4.414-7.945-4.414-13.241 0-9.71 8.828-16.772 19.421-16.772h86.51c2.648 0 4.414-.883 6.179-.883l150.069-167.724c2.648-2.648 2.648-6.179 1.766-9.71s-4.414-5.297-7.945-5.297h-44.138c-1.766 0-4.414.883-6.179 2.648l-60.028 63.559c-1.766 2.648-5.297 4.414-8.828 4.414s-7.062-1.766-9.71-4.414c-4.414-5.297-4.414-13.241.883-18.538l78.566-75.034h93.572c3.531 0 7.945 1.766 10.593 4.414l64.441 60.028c9.71 8.828 24.717 7.945 33.545-.883l45.904-46.786c4.414-4.414 13.241-4.414 17.655 0l.883.883c4.413 4.413 4.413 12.358-.001 16.772"/><path d="M406.202 114.715c29.131 0 52.966-23.834 52.966-52.966S435.333 8.784 406.202 8.784s-52.966 23.834-52.966 52.966 23.835 52.965 52.966 52.965m0-88.276c19.421 0 35.31 15.89 35.31 35.31s-15.89 35.31-35.31 35.31-35.31-15.89-35.31-35.31 15.89-35.31 35.31-35.31"/>
            </svg>
          </div>
          <h3 class="text-xl mb-3">Track and Field</h3>
          <p class="text-gray-600">Competing in Track and Field competitions and coaching kids.</p>
        </div>

        <div class="card p-6 text-center interests-item">
          <div class="w-16 h-16 mx-auto mb-4 text-primary">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
            </svg>
          </div>
          <h3 class="text-xl mb-3">Reading</h3>
          <p class="text-gray-600">I enjoy books on technology, mathematics, physics, and </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-12 bg-primary text-white">
    <div class="container text-center">
      <h2 class="section-title text-white">Want to Work Together?</h2>
      <p class="max-w-2xl mx-auto mb-10 text-white/90">
        I'm always open to new opportunities, whether it's a technical challenge or a musical performance.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="btn bg-white text-primary hover:bg-gray-100">Contact Me</a>
      </div>
    </div>
  </section>

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger} from "gsap/ScrollTrigger";

    document.addEventListener('DOMContentLoaded', () => {
      // Register GSAP plugins
      gsap.registerPlugin(ScrollTrigger);

      // Hero section animations
      gsap.from('#about-title', {
        opacity: 0,
        y: -30,
        duration: 0.8,
        ease: 'power2.out'
      });

      gsap.from('.animate-item', {
        opacity: 0,
        y: 20,
        duration: 0.6,
        stagger: 0.2,
        ease: 'power2.out'
      });

      // About image animation
      gsap.from('.about-image', {
        scrollTrigger: {
          trigger: '.about-image',
          start: 'top 80%',
        },
        opacity: 0,
        duration: 0.8,
        ease: 'power2.out'
      });

      // Animate skill bars
      const skillItems = document.querySelectorAll('.skill-progress');

      skillItems.forEach(item => {
        const level = item.getAttribute('data-level');

        gsap.to(item, {
          scrollTrigger: {
            trigger: item,
            start: 'top 98%',
          },
          width: `${level}%`,
          duration: 1,
          ease: 'power2.out'
        });
      });


      // Interests items animation
      document.querySelectorAll('.instrument-card').forEach((item, index) => {
        gsap.fromTo(item,
            {
              opacity: 0,
              y: 20
            },
            {
              scrollTrigger: {
                trigger: item,
                start: 'top 102%',
                once: true
              },
              opacity: 1,
              y: 0,
              duration: 0.2,
              delay: index * 0.05,
              ease: 'power2.out'
            }
        );
      });

      // Timeline animations
      // Tech items animation
      document.querySelectorAll('.tech-item').forEach((item, index) => {
        gsap.fromTo(item,
            {
              opacity: 0,
              x: 50
            },
            {
              scrollTrigger: {
                trigger: item,
                start: 'top 98%',
                once: true
              },
              opacity: 1,
              x: 0,
              duration: 0.4,
              delay: index * 0.1,
              ease: 'power2.out'
            }
        );
      });

      // Music items animation
      document.querySelectorAll('.music-item').forEach((item, index) => {
        gsap.fromTo(item,
            {
              opacity: 0,
              x: -50
            },
            {
              scrollTrigger: {
                trigger: item,
                start: 'top 98%',
                once: true
              },
              opacity: 1,
              x: 0,
              duration: 0.8,
              delay: index * 0.1,
              ease: 'power2.out'
            }
        );
      });

      // Interests items animation
      document.querySelectorAll('.interests-item,.instrument-card').forEach((item, index) => {
        gsap.fromTo(item,
            {
              opacity: 0,
              y: 20
            },
            {
              scrollTrigger: {
                trigger: item,
                start: 'top 98%',
                once: true
              },
              opacity: 1,
              stagger: 0.3,
              y: 0,
              duration: 0.4,
              ease: 'power2.out'
            }
        );
      });
    });
  </script>
</MainLayout>