---
import MainLayout from '../layouts/MainLayout.astro';
import SquareImage from "../components/SquareImage.astro";
import DynamicGallery from "../components/DynamicGallery.astro";

// Photography categories for portfolio showcase
const portfolioCategories = [
    {
        title: "Athletic Excellence",
        image: "/images/photography/stories/sports.jpg",
        description: "Competitive sport showcasing athletic intensity and technical precision."
    },
    {
        title: "Companionship",
        image: "/images/photography/stories/portraits.jpg",
        description: "Portraits of genuine bond between humans and pets."
    },
    {
        title: "Rural Patchwork",
        image: "/images/photography/stories/rural.jpg",
        description: "Revealing geometric patterns of German agricultural landscape."
    },
    {
        title: "Family From Above",
        image: "/images/photography/stories/family.jpg",
        description: "Capturing everyday moments from another perspective."
    },
    {
        title: "Small Worlds, Wild Lives",
        image: "/images/photography/stories/nature.jpg",
        description: "Macro details or larger wildlife, every creature tells its own unique story."
    },
    {
        title: "Precision in Flight",
        image: "/images/photography/stories/technology.jpg",
        description: "Advanced equipment that enables modern aerial photography."
    }
];

// Equipment (simplified, less commercial)
const equipment = [
    "Canon EOS R7",
    "DJI Mavic Air 2",
    "Google Pixel 8 Pro"
];

const software = [
    "Affinity Photo",
    "Affinity Designer",
    "Affinity Publisher",
    "BlackMagic Davinci Resolve"
]
---

<MainLayout title="Photography Portfolio">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-accent/10 to-accent/5 pt-24 pb-8">
        <div class="container">
            <div class="max-w-4xl mx-auto text-center">
                <h1 class="text-4xl md:text-6xl font-serif font-bold mb-6 opacity-90" id="hero-title">
                    Photography Portfolio
                </h1>
                <p class="text-xl md:text-2xl text-gray-700 mb-8 opacity-90" id="hero-subtitle">
                    Exploring the world through my lens - a personal collection of moments, places, and perspectives
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center opacity-90" id="hero-buttons">
                    <a href="#gallery" class="btn accent">View Gallery</a>
                    <a href="#about-photography" class="btn accent-transparent">About My Photography</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Portfolio Gallery -->
    <section class="py-12 bg-white">
        <div class="container">
            <h2 class="section-title text-center">Visual Stories</h2>
            <p class="text-center text-gray-600 max-w-2xl mx-auto mb-12">
                Each collection represents a different way of seeing the world. Click through to explore the stories behind these images.
            </p>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 mt-12">
                {portfolioCategories.map(category => (
                        <div class="group">
                            <div class="bg-gray-200 rounded-lg overflow-hidden mb-4">
                                <SquareImage
                                    src={category.image}
                                    alt={category.title}
                                    path=`${category.image}`
                                    square={true}
                                />
                            </div>
                            <div class="text-center">
                                <h3 class="text-xl font-serif font-semibold mb-2">{category.title}</h3>
                                <p class="text-gray-600 text-sm">{category.description}</p>
                            </div>
                        </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Featured Images Section -->
    <section id="gallery" class="py-10 bg-gray-50">
        <div class="container">
            <h2 class="section-title text-center">Recent Favorites</h2>

            <DynamicGallery layout="masonry" sortBy="date"/>
            <div class="justify-center flex mt-4"><a href="https://photo.feleuxens.de" target="_blank" class="btn accent justify-center">Whole Gallery</a></div>
        </div>
    </section>

    <!-- About Photography Section -->
    <section id="about-photography" class="py-12 bg-white">
        <div class="container">
            <div class="max-w-4xl mx-auto">
                <h2 class="section-title text-center">About My Photography</h2>

                <!--<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-16">-->
                <div class="grid grid-cols-1 lg:grid-cols-1 gap-12 items-center mb-16">
                    <div>
                        <p class="text-gray-700 mb-6 leading-relaxed">
                            Photography is a relatively new hobby that allows me to see the world through a different
                            lens. As a competitive athlete myself, I'm naturally drawn to capturing the intensity and
                            raw emotions of competitive sports.
                        </p>
                        <p class="text-gray-700 leading-relaxed">
                            While photography isn't my primary profession, it beautifully complements my technical work.
                            Both disciplines demand keen attention to detail, quick problem-solving, and the ability to
                            anticipate and capture the perfect moment from unique perspectives.
                        </p>
                    </div>

                    <!--<div class="aspect-[4/3] bg-gray-200 rounded-lg overflow-hidden">
                        <img
                                src="/images/photography/stories/rural2.jpg"
                                alt="Photographer at work"
                                class="w-full h-full object-cover"
                        />
                    </div>-->
                </div>
            </div>
        </div>
    </section>

    <!-- Equipment & Technical -->
    <section class="py-12 bg-gray-50">
        <div class="container">
            <div class="max-w-4xl mx-auto">
                <h2 class="section-title text-center">Tools & Techniques</h2>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
                    <div>
                        <h3 class="text-2xl font-serif font-semibold mb-6">Equipment</h3>
                        <p class="text-gray-600 mb-6">
                            I believe the best camera is the one you have with you, but I do have some trusted tools
                            that help me capture the images I envision.
                        </p>
                        <ul class="space-y-3">
                            {equipment.map(item => (
                                    <li class="flex items-center">
                                        <svg class="w-4 h-4 mr-3 text-accent" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                        </svg>
                                        <span class="text-gray-700">{item}</span>
                                    </li>
                            ))}
                        </ul>
                    </div>

                    <div>
                        <h3 class="text-2xl font-serif font-semibold mb-6">Software</h3>
                        <p class="text-gray-600 mb-6">
                            While cameras these days produce beautiful pictures and videos on its own, sometimes
                            some postprocessing is necessary.
                        </p>
                        <ul class="space-y-3">
                            {software.map(item => (
                                    <li class="flex items-center">
                                        <svg class="w-4 h-4 mr-3 text-accent" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                        </svg>
                                        <span class="text-gray-700">{item}</span>
                                    </li>
                            ))}
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contact for Photography -->
    <section class="py-20 bg-white">
        <div class="container">
            <div class="max-w-2xl mx-auto text-center">
                <h2 class="text-3xl font-serif font-bold mb-6">Interested in Working Together?</h2>
                <p class="text-gray-600 mb-8">
                    While photography is more of a project and hobby for me, I occasionally take on projects that
                    align with my interests and schedule. Feel free to reach out if you think we'd be a good fit.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a href="/contact" class="btn accent">Get in Touch</a>
                    <a href="/about" class="btn accent-transparent">Learn More About Me</a>
                </div>
            </div>
        </div>
    </section>

    <script>
        import { gsap } from "gsap";
        import { ScrollTrigger} from "gsap/ScrollTrigger";

        document.addEventListener('DOMContentLoaded', () => {
            // Register GSAP plugins
            gsap.registerPlugin(ScrollTrigger);

            // Hero animations
            gsap.to('#hero-title', { opacity: 1, y: 0, duration: 1, ease: 'power3.out' });
            gsap.to('#hero-subtitle', { opacity: 1, y: 0, duration: 1, delay: 0.3, ease: 'power3.out' });
            gsap.to('#hero-buttons', { opacity: 1, y: 0, duration: 1, delay: 0.6, ease: 'power3.out' });

            // Portfolio categories animation
            gsap.from('.portfolio-category', {
                scrollTrigger: {
                    trigger: '.portfolio-category',
                    start: 'top 98%',
                },
                y: 15,
                opacity: 0,
                duration: 0.25,
                stagger: 0.1,
                ease: 'power2.out'
            });
        });
    </script>
</MainLayout>