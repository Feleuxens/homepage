---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Impressum / Imprint">
    <section class="py-20 bg-white">
        <div class="container max-w-4xl mx-auto">
            <h1 class="text-4xl md:text-5xl mb-8 text-center">Impressum / Imprint</h1>

            <!-- Language Tabs -->
