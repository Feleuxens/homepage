---
// Main layout component that will be used across all pages
const { title, class: className } = Astro.props;
import "@fontsource-variable/roboto";
import "@fontsource-variable/playfair-display";
import "../styles/global.css";
import "../styles/button.css";
import "../styles/text.css";

// Dynamically compute the current year for copyright
const currentYear = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content="IT Professional, Musician, and Photographer offering technical services, music performances and photography" />
    <title>{`${title} | Felix Grüb`}</title>
    <script defer data-domain="feleuxens.de" data-api="/plausible/api/event" src="https://feleuxens.de/plausible/js/script.file-downloads.outbound-links.tagged-events.js"></script>
    <script>window.plausible = window.plausible || function() { (window.plausible.q = window.plausible.q || []).push(arguments) }</script>
  </head>
  <body class:list={["bg-gray-50 text-gray-900 min-h-screen flex flex-col", className]}>
    <header class="fixed top-0 left-0 right-0 z-50 bg-white shadow-sm">
      <div class="container mx-auto px-4 py-4">
        <nav class="flex justify-between items-center">
          <a href="/" class="font-serif text-2xl font-bold">Felix Grüb</a>

          <!-- Desktop Navigation -->
          <ul class="hidden md:flex space-x-8">
            <li><a href="/" class="font-medium ">Home</a></li>
            <li><a href="/tech-services" class="font-medium ">Tech Services</a></li>
            <li><a href="/music" class="font-medium">Music</a></li>
            <li><a href="/photography" class="font-medium">Photography</a></li>
            <li><a href="/about" class="font-medium">About</a></li>
            <li><a href="/contact" class="font-medium">Contact</a></li>
          </ul>

          <!-- Mobile menu button -->
          <button class="md:hidden flex flex-col space-y-1.5" aria-label="Toggle menu" id="menuButton">
            <span class="block w-6 h-0.5 bg-gray-800 transition-all"></span>
            <span class="block w-6 h-0.5 bg-gray-800 transition-all"></span>
            <span class="block w-6 h-0.5 bg-gray-800 transition-all"></span>
          </button>
        </nav>

        <!-- Mobile Navigation Menu (Hidden by default) -->
        <div class="md:hidden h-0 overflow-hidden transition-all duration-150" id="mobileMenu">
          <ul class="py-3 space-y-3">
            <li><a href="/" class="block py-2 font-medium">Home</a></li>
            <li><a href="/tech-services" class="block py-2 font-medium">Tech Services</a></li>
            <li><a href="/music" class="block py-2 font-medium">Music</a></li>
            <li><a href="/photography" class="block py-2 font-medium">Photography</a></li>
            <li><a href="/about" class="block py-2 font-medium">About</a></li>
            <li><a href="/contact" class="block py-2 font-medium">Contact</a></li>
          </ul>
        </div>
      </div>
    </header>

    <main class="flex-grow">
      <slot />
    </main>

    <footer class="bg-dark">
      <div class="container mx-auto px-4 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <div>
            <h3 class="text-xl mb-4">Felix Grüb</h3>
            <ul class="space-y-2">
              <li><a href="/impressum" class="dark">Impressum / Imprint</a></li>
              <li><a href="/privacy" class="dark">Datenschutzerklärung / Privacy Notice</a></li>
            </ul>
          </div>

          <div>
            <h3 class="text-xl mb-4">Connect</h3>
            <ul class="space-y-2">
              <li><a href="https://www.linkedin.com/in/felixgrueb/" class="dark">LinkedIn</a></li>
              <li><a href="https://github.com/Feleuxens" class="dark">GitHub</a></li>
              <li><a href="https://instagram.com/Feleuxens" class="dark">Instagram</a></li>
            </ul>
          </div>

          <div>
            <h3 class="text-xl mb-4"><a href="/contact" class="text-white">Contact</a></h3>
            <p class="text-gray-300">me@feleuxens.de</p>
            <!--<p class="text-gray-300">+49 xxxxxxx</p>-->
          </div>
        </div>

        <div class="border-t border-gray-700 mt-10 pt-6 text-center">
          <p class="text-gray-400 text-sm">&copy; {currentYear} Felix Grüb. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <script>
      // Mobile menu toggle
      document.addEventListener('DOMContentLoaded', () => {
        const menuButton = document.getElementById('menuButton');
        const mobileMenu = document.getElementById('mobileMenu');

        menuButton?.addEventListener('click', () => {
          menuButton.classList.toggle('active');

          if (mobileMenu?.classList.contains('h-0')) {
            mobileMenu.classList.remove('h-0');
            mobileMenu.classList.add('h-78');
          } else {
            mobileMenu?.classList.add('h-0');
            mobileMenu?.classList.remove('h-78');
          }
        });
      });
    </script>
  </body>
</html>
