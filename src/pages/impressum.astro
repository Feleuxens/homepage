                <div class="prose prose-lg max-w-none">
                    <section class="legal-section">
                        <div class="legal-content">
                            <p><strong>Felix Grüb</strong></p>
                            <p>Sielminger Hauptstraße 69/2<br>
                                70794 Filderstadt<br>
                                Deutschland</p>
                        </div>
                    </section>

                    <section class="legal-section">
                        <h2 class="legal-heading">Kontakt</h2>
                        <div class="legal-content">
                            <p><strong>E-Mail:</strong> me@feleuxens.de<br>
                                <strong>Telefon:</strong> +491789056536</p>
                        </div>
                    </section>

                    <section class="legal-section">
                        <h2 class="legal-heading">Umsatzsteuer-ID</h2>
                        <div class="legal-content">
                            <p>Umsatzsteuer-Identifikationsnummer gemäß § 27 a Umsatzsteuergesetz:<br>
                                DE363736506</p>
                        </div>
