---
import MainLayout from '../layouts/MainLayout.astro';

// Sample services data
const services = [
    {
        icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="9" />
      <path d="M8 12l9 0" />
      <path d="M12 15L17 12L12 9"/>
    </svg>`,
        title: "DevOps Implementation",
        description: "Complete DevOps transformation including CI/CD pipeline setup, automation, and infrastructure as code.",
        features: ["CI/CD Pipeline Design", "Infrastructure Automation", "Monitoring & Alerting", "Security Integration"]
    },
    {
        icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
      <line x1="8" y1="21" x2="16" y2="21"/>
      <line x1="12" y1="17" x2="12" y2="21"/>
    </svg>`,
        title: "System Administration",
        description: "Comprehensive system management, monitoring, and optimization for peak performance.",
        features: ["Server Management", "Performance Tuning", "Security Hardening", "Backup Solutions"]
    },
    {
        icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="16 18 22 12 16 6"/>
      <polyline points="8 6 2 12 8 18"/>
    </svg>`,
        title: "Containerization",
        description: "Docker and Kubernetes implementation for scalable, portable application deployment.",
        features: ["Docker Implementation", "Kubernetes Orchestration", "Container Security", "Microservices Architecture"]
    },
    {
        icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/>
      <polyline points="17,21 17,13 7,13 7,21"/>
      <polyline points="7,3 7,8 15,8"/>
    </svg>`,
        title: "Cloud Architecture",
        description: "Design and implement scalable, secure cloud infrastructure tailored to your business needs.",
        features: ["Scalability Planning", "Cost Optimization", "Disaster Recovery"]
    }
];

// Technologies/tools
const technologies = [
    { name: "Docker/Docker Compose", level: 85 },
    { name: "Python", level: 80 },
    { name: "Wireguard/Tailscale", level: 90 },
    { name: "Keycloak/OpenID Connect", level: 65 },
    { name: "GitLab CI", level: 75 },
    { name: "Grafana + Prometheus", level: 75 },
    { name: "Rust", level: 55 },
    { name: "OPNsense", level: 40 }
];

// Process steps
const process = [
    {
        step: "01",
        title: "Discovery & Assessment",
        description: "We start by understanding your current infrastructure, challenges, and goals."
    },
    {
        step: "02",
        title: "Strategy & Planning",
        description: "Develop a customized roadmap with clear milestones and success metrics."
    },
    {
        step: "03",
        title: "Implementation",
        description: "Execute the plan with regular updates and minimal disruption to your operations."
    },
    {
        step: "04",
        title: "Optimization & Support",
        description: "Continuous monitoring, optimization, and ongoing support to ensure success."
    }
];
---

<MainLayout title="Tech Services">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-primary/10 to-primary/5 pt-24 pb-8">
        <div class="container">
            <div class="max-w-2xl mx-auto text-center">
                <h1 class="text-2xl md:text-5xl font-serif font-bold mb-6 opacity-90" id="hero-title">
                    DevOps & IT Services
                </h1>
                <p class="text-xl md:text-2xl text-gray-700 mb-8 opacity-90" id="hero-subtitle">
                    Transform your infrastructure with modern DevOps practices and cloud-native solutions
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center opacity-90" id="hero-buttons">
                    <a href="/contact" class="btn primary">Start Your Project</a>
                    <!--<a href="/portfolio" class="btn primary-transparent">View Case Studies</a>-->
                </div>
            </div>
        </div>
    </section>

    <!-- Services Grid -->
    <section class="py-12 bg-white">
        <div class="container">
            <h2 class="section-title text-center">Services Offered</h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12">
                {services.map(service => (
                        <div class="service-card card p-8 hover:shadow-xl transition-all duration-300">
                            <div class="w-16 h-16 mb-6 text-primary" set:html={service.icon}></div>

                            <h3 class="text-2xl font-serif font-semibold mb-4">{service.title}</h3>
                            <p class="text-gray-600 mb-6">{service.description}</p>

                            <ul class="space-y-2">
                                {service.features.map(feature => (
                                        <li class="flex items-center text-gray-700">
                                            <svg class="w-4 h-4 mr-3 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                            </svg>
                                            {feature}
                                        </li>
                                ))}
                            </ul>
                        </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Technologies Section -->
    <section class="py-12 bg-gray-50">
        <div class="container">
            <h2 class="section-title text-center">Technologies & Tools</h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12">
                {technologies.map(tech => (
                        <div class="tech-item flex items-center justify-between p-4 bg-white rounded-lg shadow-sm">
                            <span class="font-medium text-gray-800">{tech.name}</span>
                            <div class="flex items-center ml-4">
                                <div class="w-32 h-2 bg-gray-200 rounded-full overflow-hidden">
                                    <div
                                            class="tech-progress h-full bg-primary rounded-full transition-all duration-1000"
                                            data-level={tech.level}
                                            style="width: 0%"
                                    ></div>
                                </div>
                                <span class="ml-3 text-sm text-gray-500">{tech.level}%</span>
                            </div>
                        </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Process Section -->
    <section class="py-12 bg-white">
        <div class="container">
            <h2 class="section-title text-center">My Process</h2>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mt-12">
                {process.map(item => (
                        <div class="process-item text-center">
                            <div class="w-20 h-20 rounded-full bg-primary text-white flex items-center justify-center text-2xl font-bold mb-6 mx-auto">
                                {item.step}
                            </div>
                            <h3 class="text-xl font-serif font-semibold mb-4">{item.title}</h3>
                            <p class="text-gray-600">{item.description}</p>
                        </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Why Choose Me Section -->
    <!--<section class="py-12 bg-gray-50">
        <div class="container">
            <div class="max-w-4xl mx-auto">
                <h2 class="section-title text-center">Why Choose My Services</h2>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
                    <div class="text-center">
                        <div class="w-16 h-16 mx-auto mb-4 text-primary">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 6L9 17l-5-5"/>
                            </svg>
                        </div>
                        <h3 class="text-xl font-serif font-semibold mb-3">Proven Experience</h3>
                        <p class="text-gray-600">Over X years of hands-on experience in DevOps and cloud infrastructure.</p>
                    </div>

                    <div class="text-center">
                        <div class="w-16 h-16 mx-auto mb-4 text-primary">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                            </svg>
                        </div>
                        <h3 class="text-xl font-serif font-semibold mb-3">Quality Focus</h3>
                        <p class="text-gray-600">Committed to delivering high-quality solutions that exceed expectations.</p>
                    </div>

                    <div class="text-center">
                        <div class="w-16 h-16 mx-auto mb-4 text-primary">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                            </svg>
                        </div>
