                        <h2 class="legal-heading">VAT Identification Number</h2>
                        <div class="legal-content">
                            <p>VAT identification number according to § 27 a Value Added Tax Act:<br>
                                DE363736506</p>
                        </div>
                    </section>

                    <!-- EU Dispute Resolution -->
