---
import MainLayout from '../layouts/MainLayout.astro';

// Contact information
const contactInfo = {
    email: "me@feleuxens.de",
    phone: "+1 (555) 123-4567",
    location: "Filderstadt",
    availability: "Monday - Friday, 9:00 AM - 5:00 PM"
};

// Service areas
const serviceAreas = [
    "Technology Consulting",
    "System Administration",
    "Software Development",
    "Piano/Trumpet Performances",
    "Arrangement or Transcription",
    "Photography Services"
];

// FAQ items
const faqs = [
    {
        question: "How far in advance should I book?",
        answer: "For tech consulting projects, I recommend 2-4 weeks notice. For piano performances and photography, 4-6 weeks is ideal, especially during peak wedding season."
    },
    {
        question: "Do you travel for events?",
        answer: "Yes! I'm happy to travel for events within a 100-mile radius. Travel fees may apply for locations beyond 50 miles."
    },
    {
        question: "What's included in your services?",
        answer: "Each service includes pre-consultation, professional execution, and follow-up. Specific deliverables vary by service type - contact me for detailed information."
    },
    {
        question: "Can you handle last-minute requests?",
        answer: "I'll do my best to accommodate urgent requests when possible. Emergency rates may apply for requests with less than 48 hours notice."
    }
];
---

<MainLayout title="Contact">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-gray-100 to-gray-50 pt-24 pb-8">
        <div class="container">
            <div class="max-w-4xl mx-auto text-center">
                <h1 class="text-4xl md:text-6xl font-serif font-bold mb-6 opacity-90" id="hero-title">
                    Get In Touch
                </h1>
                <p class="text-xl md:text-2xl text-gray-700 mb-8 opacity-90" id="hero-subtitle">
                    Ready to start your project? Let's discuss how I can help bring your vision to life.
                </p>
            </div>
        </div>
    </section>

    <!-- Contact Form & Info Section -->
    <section class="py-12 bg-white">
        <div class="container">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
                <!-- Contact Form -->
                <div class="contact-form">
                    <h2 class="text-3xl font-serif font-bold mb-8">Send me a message</h2>

                    <form class="space-y-6" id="contact-form">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label for="firstName" class="block text-sm font-medium text-gray-700 mb-2">First Name *</label>
                                <input
                                        type="text"
                                        id="firstName"
                                        name="firstName"
                                        required
                                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors"
                                        placeholder="Max"
                                />
                            </div>
                            <div>
                                <label for="lastName" class="block text-sm font-medium text-gray-700 mb-2">Last Name *</label>
                                <input
                                        type="text"
                                        id="lastName"
                                        name="lastName"
                                        required
                                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors"
                                        placeholder="Mustermann"
                                />
                            </div>
                        </div>

                        <div>
                            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email Address *</label>
                            <input
                                    type="email"
                                    id="email"
                                    name="email"
                                    required
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors"
                                    placeholder="max@example.de"
                            />
                        </div>

                        <div>
                            <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">Phone Number</label>
                            <input
                                    type="tel"
                                    id="phone"
                                    name="phone"
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors"
                                    placeholder="+49 123 456789"
                            />
                        </div>

                        <div>
                            <label for="service" class="block text-sm font-medium text-gray-700 mb-2">Service Interested In *</label>
                            <select
                                    id="service"
                                    name="service"
                                    required
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors"
                            >
                                <option value="">Select a service...</option>
                                <option value="it">DevOps & IT Services</option>
                                <option value="performance">Piano/Trumpet Performance</option>
                                <option value="arrangement">Arrangement or Transcription</option>
                                <option value="photography">Photography</option>
                                <option value="other">Other</option>
                            </select>
                        </div>

                        <div>
                            <label for="eventDate" class="block text-sm font-medium text-gray-700 mb-2">Event/Project Date</label>
                            <input
                                    type="date"
                                    id="eventDate"
                                    name="eventDate"
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors"
                            />
                        </div>

                        <div>
                            <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Project Details *</label>
                            <textarea
                                    id="message"
                                    name="message"
                                    rows="5"
                                    required
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors resize-vertical"
                                    placeholder="Please describe your project, event details, timeline, and any specific requirements..."
                            ></textarea>
                        </div>

                        <div class="flex items-start">
                            <input
                                    type="checkbox"
                                    id="privacy"
                                    name="privacy"
                                    required
                                    class="mt-1 mr-3 h-4 w-4 text-primary focus:ring-primary border-gray-300 rounded"
                            />
                            <label for="privacy" class="text-sm text-gray-600">
                                I agree to the <a href="/privacy" class="text-primary hover:underline" target="_blank">privacy policy</a> and consent to being contacted about my inquiry. *
                            </label>
                        </div>

                        <button
                                type="submit"
                                class="w-full btn btn-primary py-4 text-lg font-medium"
                                id="submit-btn"
                        >
                            Send Message
                        </button>

                        <div id="form-message" class="text-center text-sm hidden"></div>
                    </form>
                </div>

                <!-- Contact Information -->
                <div class="contact-info">
                    <h2 class="text-3xl font-serif font-bold mb-8">Contact Information</h2>

                    <div class="space-y-6 mb-10">
                        <div class="flex items-start">
                            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mr-4 mt-1">
                                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-semibold text-lg">Email</h3>
                                <p class="text-gray-600">{contactInfo.email}</p>
                                <p class="text-sm text-gray-500">Best for detailed inquiries</p>
                            </div>
                        </div>

                        <div class="flex items-start">
                            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mr-4 mt-1">
                                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-semibold text-lg">Phone</h3>
                                <p class="text-gray-600">{contactInfo.phone}</p>
                                <p class="text-sm text-gray-500">Quick questions & urgent requests</p>
                            </div>
                        </div>

                        <div class="flex items-start">
                            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mr-4 mt-1">
                                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-semibold text-lg">Location</h3>
                                <p class="text-gray-600">{contactInfo.location}</p>
                                <p class="text-sm text-gray-500">Available for regional travel</p>
                            </div>
                        </div>

                        <div class="flex items-start">
                            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mr-4 mt-1">
                                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-semibold text-lg">Availability</h3>
                                <p class="text-gray-600">{contactInfo.availability}</p>
                                <p class="text-sm text-gray-500">Response within 24 hours</p>
                            </div>
                        </div>
                    </div>

                    <!-- Services Available -->
                    <div class="bg-gray-50 rounded-lg p-6 mb-8">
                        <h3 class="font-semibold text-lg mb-4">Services Available</h3>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                            {serviceAreas.map(service => (
                                    <div class="flex items-center">
                                        <svg class="w-4 h-4 mr-2 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                        </svg>
                                        <span class="text-sm text-gray-700">{service}</span>
                                    </div>
                            ))}
                        </div>
                    </div>

                    <!-- Social Links -->
                    <div>
                        <h3 class="font-semibold text-lg mb-4">Connect With Me</h3>
                        <div class="flex space-x-4">
                            <a href="#" class="w-10 h-10 bg-primary text-white rounded-lg flex items-center justify-center hover:bg-primary/80 transition-colors">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                                </svg>
                            </a>
                            <a href="#" class="w-10 h-10 bg-dark text-white rounded-lg flex items-center justify-center hover:bg-dark/80 transition-colors">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                                </svg>
                            </a>
                            <a href="#" class="w-10 h-10 bg-blue-500 text-white rounded-lg flex items-center justify-center hover:bg-blue-400 transition-colors">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-12 bg-gray-50">
        <div class="container">
            <h2 class="section-title text-center">Frequently Asked Questions</h2>

            <div class="max-w-4xl mx-auto mt-12 space-y-6">
                {faqs.map((faq, index) => (
                        <div class="faq-item bg-white rounded-lg shadow-sm">
                            <button
                                    class="w-full px-6 py-4 text-left flex justify-between items-center hover:bg-gray-50 focus:outline-none focus:bg-gray-50 transition-colors"
                                    onclick={`toggleFAQ(${index})`}
                            >
                                <span class="font-semibold text-lg">{faq.question}</span>
                                <svg class="w-5 h-5 text-gray-400 transform transition-transform" id={`faq-icon-${index}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                                </svg>
                            </button>
                            <div class="faq-answer px-6 pb-0 overflow-hidden transition-all duration-300" id={`faq-answer-${index}`} style="max-height: 0;">
                                <div class="pb-4 text-gray-600 border-t border-gray-100 pt-4">
                                    {faq.answer}
                                </div>
                            </div>
                        </div>
                ))}
            </div>
        </div>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Register GSAP plugins
            gsap.registerPlugin(ScrollTrigger);

            // Hero animations
            gsap.to('#hero-title', { opacity: 1, y: 0, duration: 1, ease: 'power3.out' });
            gsap.to('#hero-subtitle', { opacity: 1, y: 0, duration: 1, delay: 0.3, ease: 'power3.out' });

            // Form animations
            gsap.from('.contact-form', {
                scrollTrigger: {
                    trigger: '.contact-form',
                    start: 'top 98%',
                },
                x: -50,
                opacity: 0,
                duration: 0.8,
                ease: 'power2.out'
            });

            gsap.from('.contact-info', {
                scrollTrigger: {
                    trigger: '.contact-info',
                    start: 'top 98%',
                },
                x: 50,
                opacity: 0,
                duration: 0.8,
                ease: 'power2.out'
            });

            gsap.from('.faq-item', {
                scrollTrigger: {
                    trigger: '.faq-item',
                    start: 'top 98%',
                },
                y: 30,
                opacity: 0,
                duration: 0.6,
                stagger: 0.1,
                ease: 'power2.out'
            });
        });

        // FAQ toggle functionality
        function toggleFAQ(index) {
            const answer = document.getElementById(`faq-answer-${index}`);
            const icon = document.getElementById(`faq-icon-${index}`);

            if (answer.style.maxHeight && answer.style.maxHeight !== '0px') {
                answer.style.maxHeight = '0px';
                icon.style.transform = 'rotate(0deg)';
            } else {
                answer.style.maxHeight = answer.scrollHeight + 'px';
                icon.style.transform = 'rotate(180deg)';
            }
        }

        // Form submission handler
        document.getElementById('contact-form').addEventListener('submit', function(e) {
            e.preventDefault();

            const submitBtn = document.getElementById('submit-btn');
            const messageDiv = document.getElementById('form-message');

            // Show loading state
            submitBtn.disabled = true;
            submitBtn.textContent = 'Sending...';

            // Simulate form submission (replace with actual form handling)
            setTimeout(() => {
                messageDiv.className = 'text-center text-sm text-green-600';
                messageDiv.textContent = 'Thank you! Your message has been sent successfully. I\'ll get back to you within 24 hours.';
                messageDiv.classList.remove('hidden');

                // Reset form
                this.reset();

                // Reset button
                submitBtn.disabled = false;
                submitBtn.textContent = 'Send Message';

                // Hide message after 5 seconds
                setTimeout(() => {
                    messageDiv.classList.add('hidden');
                }, 5000);
            }, 2000);
        });
    </script>
</MainLayout>