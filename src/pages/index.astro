---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Home">
  <!-- Hero Section -->
  <section class="relative h-screen flex items-center justify-center overflow-hidden">
    <!-- Background Image with Overlay -->
    <div class="absolute inset-0 bg-gradient-to-r from-black/70 to-black/50 z-10"></div>
    <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/hero-bg.jpg')"></div>

    <!-- Hero Content -->
    <div class="container relative z-20 text-center text-white">
      <h1 class="font-serif text-4xl md:text-6xl font-bold mb-4 opacity-0" id="hero-title">Your Name</h1>
      <p class="text-xl md:text-2xl mb-8 max-w-2xl mx-auto opacity-0" id="hero-subtitle">
        Technical Solutions & Musical Performances
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center opacity-0" id="hero-buttons">
        <a href="/tech-services" class="btn btn-primary">DevOps Services</a>
        <a href="/music" class="btn btn-secondary">Piano Performances</a>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="py-20 bg-white">
    <div class="container">
      <h2 class="section-title text-center">What I Offer</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12">
        <!-- DevOps Card -->
        <div class="card p-8 service-card">
          <div class="w-16 h-16 mb-6 text-primary">
            <!-- DevOps Icon (SVG) -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect>
              <rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect>
              <line x1="6" y1="6" x2="6.01" y2="6"></line>
              <line x1="6" y1="18" x2="6.01" y2="18"></line>
            </svg>
          </div>

          <h3 class="font-serif text-2xl font-semibold mb-4">DevOps & IT Services</h3>
          <p class="text-gray-600 mb-6">
            Professional infrastructure setup, CI/CD pipelines, cloud architecture, and system automation tailored to your business needs.
          </p>
          <a href="/tech-services" class="inline-flex items-center font-medium text-primary hover:text-primary/80">
            Learn More
            <svg class="w-4 h-4 ml-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"></path>
              <path d="M12 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>

        <!-- Music Card -->
        <div class="card p-8 service-card">
          <div class="w-16 h-16 mb-6 text-primary">
            <!-- Music Icon (SVG) -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18V5l12-2v13"></path>
              <circle cx="6" cy="18" r="3"></circle>
              <circle cx="18" cy="16" r="3"></circle>
            </svg>
          </div>

          <h3 class="font-serif text-2xl font-semibold mb-4">Piano Performances</h3>
          <p class="text-gray-600 mb-6">
            Elegant piano music for weddings, funerals, corporate events, and private gatherings. Customized repertoire to suit your occasion.
          </p>
          <a href="/music" class="inline-flex items-center font-medium text-primary hover:text-primary/80">
            Learn More
            <svg class="w-4 h-4 ml-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"></path>
              <path d="M12 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio Preview -->
  <section class="py-20 bg-gray-100">
    <div class="container">
      <h2 class="section-title text-center">Featured Work</h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 mt-12">
        <!-- Portfolio Item 1 -->
        <div class="card portfolio-item">
          <div class="aspect-video bg-gray-200 overflow-hidden">
            <img
              src="/images/portfolio-1.jpg"
              alt="Cloud Infrastructure Project"
              class="w-full h-full object-cover transition duration-300 hover:scale-105"
            />
          </div>
          <div class="p-6">
            <h3 class="font-serif text-xl font-semibold mb-2">Cloud Migration</h3>
            <p class="text-gray-600">Complete AWS infrastructure implementation</p>
          </div>
        </div>

        <!-- Portfolio Item 2 -->
        <div class="card portfolio-item">
          <div class="aspect-video bg-gray-200 overflow-hidden">
            <img
              src="/images/portfolio-2.jpg"
              alt="Wedding Performance"
              class="w-full h-full object-cover transition duration-300 hover:scale-105"
            />
          </div>
          <div class="p-6">
            <h3 class="font-serif text-xl font-semibold mb-2">Wedding Performance</h3>
            <p class="text-gray-600">Classical piano at The Grand Hotel</p>
          </div>
        </div>

        <!-- Portfolio Item 3 -->
        <div class="card portfolio-item">
          <div class="aspect-video bg-gray-200 overflow-hidden">
            <img
              src="/images/portfolio-3.jpg"
              alt="CI/CD Pipeline"
              class="w-full h-full object-cover transition duration-300 hover:scale-105"
            />
          </div>
          <div class="p-6">
            <h3 class="font-serif text-xl font-semibold mb-2">CI/CD Architecture</h3>
            <p class="text-gray-600">Automated deployment pipeline for fintech client</p>
          </div>
        </div>
      </div>

      <div class="text-center mt-12">
        <a href="/portfolio" class="btn btn-primary">View Full Portfolio</a>
      </div>
    </div>
  </section>

  <!-- About Preview Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="about-image">
          <img
            src="/images/about-me.jpg"
            alt="Your Name"
            class="rounded-lg shadow-xl w-full max-w-md mx-auto"
          />
        </div>

        <div class="about-content">
          <h2 class="section-title">About Me</h2>
          <p class="text-gray-600 mb-6">
            I combine technical expertise in DevOps and cloud infrastructure with classical piano training, offering a unique blend of services to diverse clients.
          </p>
          <p class="text-gray-600 mb-8">
            With over X years in the IT industry and a lifelong passion for music, I bring both analytical precision and creative expression to everything I do.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/about" class="btn btn-primary">Learn More About Me</a>
            <a href="/cv" class="btn btn-secondary">View My CV</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Preview -->
  <section class="py-20 bg-primary text-white">
    <div class="container text-center">
      <h2 class="section-title text-white">Let's Work Together</h2>
      <p class="max-w-2xl mx-auto mb-10 text-white/90">
        Whether you need technical expertise for your infrastructure or beautiful piano music for your event, I'm here to help.
      </p>
      <a href="/contact" class="btn bg-white text-primary hover:bg-gray-100">Contact Me</a>
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Register GSAP plugins
      gsap.registerPlugin(ScrollTrigger);

      // Hero section animations
      gsap.to('#hero-title', { opacity: 1, y: 0, duration: 1, ease: 'power3.out' });
      gsap.to('#hero-subtitle', { opacity: 1, y: 0, duration: 1, delay: 0.3, ease: 'power3.out' });
      gsap.to('#hero-buttons', { opacity: 1, y: 0, duration: 1, delay: 0.6, ease: 'power3.out' });

      // Service cards animation
      gsap.from('.service-card', {
        scrollTrigger: {
          trigger: '.service-card',
          start: 'top 80%',
        },
        y: 50,
        opacity: 0,
        duration: 0.8,
        stagger: 0.2,
        ease: 'power2.out'
      });

      // Portfolio items animation
      gsap.from('.portfolio-item', {
        scrollTrigger: {
          trigger: '.portfolio-item',
          start: 'top 80%',
        },
        y: 30,
        opacity: 0,
        duration: 0.6,
        stagger: 0.15,
        ease: 'power2.out'
      });

      // About section animation
      gsap.from('.about-image', {
        scrollTrigger: {
          trigger: '.about-image',
          start: 'top 80%',
        },
        x: -50,
        opacity: 0,
        duration: 1,
        ease: 'power2.out'
      });

      gsap.from('.about-content', {
        scrollTrigger: {
          trigger: '.about-content',
          start: 'top 80%',
        },
        x: 50,
        opacity: 0,
        duration: 1,
        ease: 'power2.out'
      });
    });
  </script>
</MainLayout>
