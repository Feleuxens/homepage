---
import MainLayout from '../layouts/MainLayout.astro';

const technicalSkills = [
  { name: "x", level: 90 },
  { name: "x", level: 85 },
  { name: "x", level: 88 },
  { name: "x", level: 82 },
  { name: "x", level: 75 }
];

const musicalSkills = [
  { name: "x", level: 95 },
  { name: "x", level: 80 },
  { name: "x", level: 70 },
  { name: "x", level: 85 },
  { name: "x", level: 90 }
];

/* Example timeline entry
{
  startYear: "",
  endYear: "0000 or present",
  title: "",
  company: "",
  description: "",
  type: "tech or music"
}
*/
const timeline: object = [
  {
    startYear: 2023,
    endYear: "present",
    title: "Working Student for DevOps and Software Development",
    company: "intension GmbH",
    description: "",
    type: "tech"
  },
  {
    startYear: 2020,
    endYear: "present",
    title: "Test",
    company: "",
    description: "",
    type: "tech"
  },
  {
    startYear: 2020,
    endYear: 2020,
    title: "Music exam in A-levels",
    company: "",
    description: "Played",
    type: "music"
  },
  {
    startYear: 2008,
    endYear: 2020,
    title: "Trumpet lessons",
    company: "",
    description: "",
    type: "music"
  },
  {
    startYear: 2016,
    endYear: 2023,
    title: "Piano lessons",
    company: "",
    description: "",
    type: "music"
  },
];

// Set current year for "present" calculations
const currentYear = new Date().getFullYear();

// Helper function to get actual end year
function getEndYear(endYear) {
  return endYear === "present" ? currentYear : endYear;
}

// Get earliest and latest years
const earliestYear = Math.min(...timeline.map(item => item.startYear));
const earliestEndYear = Math.min(...timeline.map(item => getEndYear(item.endYear)));
const latestYear = Math.max(...timeline.map(item => getEndYear(item.endYear)));
const yearSpan = latestYear - earliestYear + 1;
const endYearSpan = latestYear - earliestEndYear + 1;

// Function to position items based on end year with overlap prevention
function positionTimelineItems(items) {
  // First, sort by end year (descending)
  const sortedItems = [...items].sort((a, b) =>
    getEndYear(a.endYear) - getEndYear(b.endYear)
  );

  // Then position each item
  const cardHeightPx = 120; // Estimated card height
  const cardSpacingPx = 30; // Minimum gap between cards
  const usedPositions = []; // Track used positions in pixels

  sortedItems.forEach(item => {
    // Get position based on end year in pixel units
    const endYearPos = ((getEndYear(item.endYear) - earliestYear) / yearSpan) * 550; // 700px is roughly the desired total height
    let position = endYearPos;

    // Check for overlaps
    let hasOverlap = true;
    while (hasOverlap) {
      hasOverlap = false;

      for (const usedPos of usedPositions) {
        const minSpace = cardHeightPx + cardSpacingPx;
        if (Math.abs(position - usedPos) < minSpace) {
          // Found an overlap, shift this item down
          position = usedPos + minSpace;
          hasOverlap = true;
        }
      }
    }

    // Store the pixel position
    item.positionPx = position;
    usedPositions.push(position);
  });

  // Calculate total height needed
  const maxPosition = Math.max(...usedPositions) + cardHeightPx + 50; // +50px padding

  // Convert positions to percentages based on total height
  sortedItems.forEach(item => {
    item.position = 100 - (item.positionPx / maxPosition) * 100;
  });

  return {
    items: sortedItems,
    totalHeight: maxPosition
  };
}

// Separate and position tech and music items
const techItems = timeline.filter(item => item.type === "tech");
const musicItems = timeline.filter(item => item.type === "music");

const techResult = positionTimelineItems(techItems);
const musicResult = positionTimelineItems(musicItems);

// Calculate final timeline height
const timelineHeight = Math.max(techResult.totalHeight, musicResult.totalHeight);
---

<MainLayout title="About Me">
  <!-- Hero Section -->
  <section class="bg-gray-100 py-20">
    <div class="container">
      <h1 class="section-title text-center mb-12" id="about-title">About Me</h1>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="about-image">
          <img
            src="/images/about-me-large.jpg"
            alt="Your Name"
            class="rounded-lg shadow-xl w-full"
          />
        </div>

        <div class="about-content space-y-6">
          <h2 class="font-serif text-3xl font-semibold animate-item">Hello, I'm Your Name</h2>

          <p class="text-gray-700 animate-item">
            Some text
          </p>

          <p class="text-gray-700 animate-item">
            More text
          </p>

          <div class="flex flex-col sm:flex-row gap-4 animate-item">
            <a href="/cv" class="btn btn-primary">View My CV</a>
            <a href="/contact" class="btn btn-secondary">Contact Me</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section class="py-20 bg-white">
    <div class="container">
      <h2 class="section-title text-center">My Skills</h2>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 mt-12">
        <!-- Technical Skills -->
        <div class="skills-category">
          <h3 class="font-serif text-2xl font-semibold mb-8 text-center">Technical Skills</h3>

          <div class="space-y-6">
            {technicalSkills.map(skill => (
              <div class="skill-item">
                <div class="flex justify-between mb-2">
                  <span class="font-medium">{skill.name}</span>
                  <span class="text-gray-500">{skill.level}%</span>
                </div>
                <div class="h-2 bg-gray-200 rounded-full overflow-hidden">
                  <div
                    class="skill-progress bg-primary h-full rounded-full"
                    data-level={skill.level}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Musical Skills -->
        <div class="skills-category">
          <h3 class="font-serif text-2xl font-semibold mb-8 text-center">Musical Skills</h3>

          <div class="space-y-6">
            {musicalSkills.map(skill => (
              <div class="skill-item">
                <div class="flex justify-between mb-2">
                  <span class="font-medium">{skill.name}</span>
                  <span class="text-gray-500">{skill.level}%</span>
                </div>
                <div class="h-2 bg-gray-200 rounded-full overflow-hidden">
                  <div
                    class="skill-progress bg-secondary h-full rounded-full"
                    data-level={skill.level}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline Section -->
  <section class="py-20 bg-gray-100">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-serif font-bold text-center mb-12">My Journey</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
        <!-- Column Headers -->
        <div class="text-center">
          <div class="inline-block px-4 py-2 bg-primary text-white rounded-lg font-medium">
            Technology Career
          </div>
        </div>
        <div class="text-center">
          <div class="inline-block px-4 py-2 bg-secondary text-white rounded-lg font-medium">
            Music Career
          </div>
        </div>
      </div>

      <!-- Timeline -->
      <div class="relative">
        <!-- Center line -->
        <div class="absolute left-1/2 transform -translate-x-1/2 w-1 bg-gray-300" style={`height: ${timelineHeight}px;`}></div>

        <!-- Year markers - only major years -->
        <div class="hidden md:block">
          {Array.from({ length: endYearSpan }).map((_, i) => {
            const year = latestYear - i;
            return (
              <div class="absolute left-1/2 transform -translate-x-16 flex items-center"
                  style={`top: ${((latestYear - year) / yearSpan) * 100}%;`}>
                <div class="text-xs font-medium text-gray-500">{year}</div>
                <div class="w-4 h-px bg-gray-300 ml-1"></div>
              </div>
            )
          })}
        </div>

        <!-- Timeline items container -->
        <div class="relative" style={`height: ${timelineHeight}px;`}>
          <!-- Tech Items (Left) -->
          {techResult.items.map(item => (
            <div class="absolute left-0 md:w-[calc(50%-20px)] w-full" style={`top: ${item.position}%;`}>
              <div class="relative pr-8 md:pr-12">
                <!-- Timeline connector -->
                <div class="absolute right-0 top-8 h-0.5 w-8 bg-primary/60 hidden md:block"></div>

                <!-- End year dot -->
                <div class="absolute right-0 top-8 w-4 h-4 rounded-full bg-primary hidden md:block"></div>

                <!-- Card -->
                <div class="card bg-white rounded-lg shadow-md p-4 border-l-4 border-primary">
                  <div class="flex justify-between items-center mb-3">
                    <div class="px-3 py-1 text-sm font-medium bg-primary/10 text-primary rounded-full">
                      {item.startYear} - {item.endYear}
                    </div>

                    {item.endYear === "present" && (
                      <span class="text-xs px-2 py-1 bg-green-100 text-green-800 rounded-full">
                        Current
                      </span>
                    )}
                  </div>

                  <h3 class="text-xl font-serif font-semibold">{item.title}</h3>
                  <p class="text-gray-600 font-medium text-sm mt-1">{item.company}</p>
                  <p class="text-gray-700 mt-2">{item.description}</p>
                </div>
              </div>
            </div>
          ))}

          <!-- Music Items (Right) -->
          {musicResult.items.map(item => (
            <div class="absolute right-0 md:w-[calc(50%-20px)] w-full" style={`top: ${item.position}%;`}>
              <div class="relative pl-8 md:pl-12">
                <!-- Timeline connector -->
                <div class="absolute left-0 top-8 h-0.5 w-8 bg-secondary/60 hidden md:block"></div>

                <!-- End year dot -->
                <div class="absolute left-0 top-8 w-4 h-4 rounded-full bg-secondary hidden md:block"></div>

                <!-- Card -->
                <div class="card bg-white rounded-lg shadow-md p-4 border-l-4 border-secondary">
                  <div class="flex justify-between items-center mb-3">
                    <div class="px-3 py-1 text-sm font-medium bg-secondary/10 text-secondary rounded-full">
                      {item.startYear} - {item.endYear}
                    </div>

                    {item.endYear === "present" && (
                      <span class="text-xs px-2 py-1 bg-green-100 text-green-800 rounded-full">
                        Current
                      </span>
                    )}
                  </div>

                  <h3 class="text-xl font-serif font-semibold">{item.title}</h3>
                  <p class="text-gray-600 font-medium text-sm mt-1">{item.company}</p>
                  <p class="text-gray-700 mt-2">{item.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Personal Interests -->
  <section class="py-20 bg-white">
    <div class="container">
      <h2 class="section-title text-center">Personal Interests</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
        <div class="card p-6 text-center interests-item">
          <div class="w-16 h-16 mx-auto mb-4 text-primary">
            <!-- Book Icon -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
            </svg>
          </div>
          <h3 class="font-serif text-xl font-semibold mb-3">Reading</h3>
          <p class="text-gray-600">I enjoy books on technology, music theory, and science fiction.</p>
        </div>

        <div class="card p-6 text-center interests-item">
          <div class="w-16 h-16 mx-auto mb-4 text-primary">
            <svg viewBox="0 0 550 550" fill="currentColor" stroke="currentColor" stroke-width="10" stroke-linecap="round" stroke-linejoin="round">
              <path d="m503.306 111.184-.883-.883c-11.476-11.476-31.779-11.476-43.255 0l-45.903 46.786c-2.648 2.648-6.179 2.648-8.828 0L339.995 97.06c-6.179-5.297-14.124-8.828-22.952-8.828h-96.221c-2.648 0-4.414.883-5.297 1.766l-81.214 77.683c-11.476 12.359-12.359 31.779-1.766 43.255 5.297 6.179 13.241 9.71 22.069 9.71s16.772-3.531 22.069-9.71l57.379-60.91h20.303L120.188 300.094H37.209c-20.303 0-36.193 15.007-37.076 33.545-.883 9.71 2.648 19.421 9.71 26.483 7.062 6.179 15.89 10.593 25.6 10.593H159.03c2.648 0 4.414-.883 6.179-2.648l63.559-67.972 52.965 55.614-15.89 102.4c-4.414 17.655 4.414 34.428 19.421 41.49 5.297 2.648 9.71 3.531 15.007 3.531s10.593-.883 15.89-3.531c8.828-4.414 15.89-13.241 18.538-23.835l27.365-147.421c0-2.648-.883-6.179-2.648-7.945l-73.269-73.269 58.262-58.262 40.607 40.607c11.476 11.476 30.897 11.476 42.372 0l75.917-75.917c11.477-11.477 11.477-30.897.001-42.373m-12.359 30.014-75.917 75.917c-5.297 4.414-13.241 4.414-17.655 0l-46.786-46.786c-3.531-3.531-8.828-3.531-12.359 0l-70.621 70.621c-1.766 1.766-2.648 3.531-2.648 6.179s.883 4.414 3.531 7.062l75.917 75.917-26.483 142.124c-1.766 4.414-5.297 8.828-9.71 11.476-4.414 1.766-9.71 2.648-15.007 0-7.945-3.531-11.476-12.359-9.71-22.069l16.772-107.697c0-2.648-.883-5.297-2.648-7.062l-62.676-65.324c-1.766-1.766-3.531-2.648-6.179-2.648s-5.297.883-6.179 2.648l-67.09 71.503H35.444q-7.945 0-13.241-5.297c-2.648-3.531-4.414-7.945-4.414-13.241 0-9.71 8.828-16.772 19.421-16.772h86.51c2.648 0 4.414-.883 6.179-.883l150.069-167.724c2.648-2.648 2.648-6.179 1.766-9.71s-4.414-5.297-7.945-5.297h-44.138c-1.766 0-4.414.883-6.179 2.648l-60.028 63.559c-1.766 2.648-5.297 4.414-8.828 4.414s-7.062-1.766-9.71-4.414c-4.414-5.297-4.414-13.241.883-18.538l78.566-75.034h93.572c3.531 0 7.945 1.766 10.593 4.414l64.441 60.028c9.71 8.828 24.717 7.945 33.545-.883l45.904-46.786c4.414-4.414 13.241-4.414 17.655 0l.883.883c4.413 4.413 4.413 12.358-.001 16.772"/><path d="M406.202 114.715c29.131 0 52.966-23.834 52.966-52.966S435.333 8.784 406.202 8.784s-52.966 23.834-52.966 52.966 23.835 52.965 52.966 52.965m0-88.276c19.421 0 35.31 15.89 35.31 35.31s-15.89 35.31-35.31 35.31-35.31-15.89-35.31-35.31 15.89-35.31 35.31-35.31"/>
            </svg>
          </div>
          <h3 class="font-serif text-xl font-semibold mb-3">Track and Field</h3>
          <p class="text-gray-600">Competing in Track and Field competitions and coaching kids.</p>
        </div>

        <div class="card p-6 text-center interests-item">
          <div class="w-16 h-16 mx-auto mb-4 text-primary">
            <!-- Coffee Icon -->
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 8h1a4 4 0 0 1 0 8h-1"></path>
              <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"></path>
              <line x1="6" y1="1" x2="6" y2="4"></line>
              <line x1="10" y1="1" x2="10" y2="4"></line>
              <line x1="14" y1="1" x2="14" y2="4"></line>
            </svg>
          </div>
          <h3 class="font-serif text-xl font-semibold mb-3">Coffee</h3>
          <p class="text-gray-600">Exploring artisanal coffee shops and brewing techniques.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Call to Action -->
  <section class="py-20 bg-primary text-white">
    <div class="container text-center">
      <h2 class="section-title text-white">Want to Work Together?</h2>
      <p class="max-w-2xl mx-auto mb-10 text-white/90">
        I'm always open to new opportunities, whether it's a technical challenge or a musical performance.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="btn bg-white text-primary hover:bg-gray-100">Contact Me</a>
        <a href="/cv" class="btn bg-transparent border-2 border-white text-white hover:bg-white/10">View My CV</a>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Register GSAP plugins
      gsap.registerPlugin(ScrollTrigger);

      // Hero section animations
      gsap.from('#about-title', {
        opacity: 0,
        y: -30,
        duration: 0.8,
        ease: 'power2.out'
      });

      gsap.from('.animate-item', {
        opacity: 0,
        y: 20,
        duration: 0.6,
        stagger: 0.2,
        ease: 'power2.out'
      });

      // About image animation
      gsap.from('.about-image', {
        scrollTrigger: {
          trigger: '.about-image',
          start: 'top 80%',
        },
        opacity: 0,
        x: -50,
        duration: 0.8,
        ease: 'power2.out'
      });

      // Animate skill bars
      const skillItems = document.querySelectorAll('.skill-progress');

      skillItems.forEach(item => {
        const level = item.getAttribute('data-level');

        gsap.to(item, {
          scrollTrigger: {
            trigger: item,
            start: 'top 90%',
          },
          width: `${level}%`,
          duration: 1.2,
          ease: 'power2.out'
        });
      });

      // Timeline animations
      // Tech items animation
      gsap.from('.tech-item', {
        scrollTrigger: {
          trigger: '.timeline-item',
          start: 'top 80%',
        },
        opacity: 0,
        x: 50,
        duration: 0.8,
        stagger: 0.2,
        ease: 'power2.out'
      });

      // Music items animation
      gsap.from('.music-item', {
        scrollTrigger: {
          trigger: '.timeline-item',
          start: 'top 80%',
        },
        opacity: 0,
        x: -50,
        duration: 0.8,
        stagger: 0.2,
        ease: 'power2.out'
      });

      // Interests items animation
      gsap.from('.interests-item', {
        scrollTrigger: {
          trigger: '.interests-item',
          start: 'top 80%',
        },
        opacity: 0,
        y: 30,
        duration: 0.6,
        stagger: 0.15,
        ease: 'power2.out'
      });
    });
  </script>
</MainLayout>
