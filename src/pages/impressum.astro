                                data-tab="german"
                                id="german-tab"
                        >
                            <span class="text-lg">🇩🇪</span>
                            <span>Deutsch</span>
                        </button>
                        <button
                                class="tab-button px-6 py-3 rounded-md font-medium transition-all duration-200 flex items-center space-x-2"
                                data-tab="english"
                                id="english-tab"
                        >
                            <span class="text-lg">🇬🇧</span>
                            <span>English</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- German Content -->
            <div class="tab-content active" id="german-content">
