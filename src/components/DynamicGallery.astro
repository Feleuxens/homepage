---
import { Image } from 'astro:assets';
import { exifData } from "../data/exif-data.js";
import SquareImage from "./SquareImage.astro";

interface Props {
    layout?: 'masonry' | 'grid';
    sortBy?: 'date' | 'filename' | 'random';
    maxImages?: number;
}

const {
    layout = 'grid',
    sortBy = 'date',
    maxImages,
} = Astro.props;

let folder = "/images/photography/favorites/";
const imageModules = import.meta.glob('../../public/images/photography/favorites/*.{jpg,jpeg,png,webp,JPG}');
const images = await Promise.all(
Object.entries(imageModules).map(async ([path, importFn]) => {
    const module = await importFn();
    const filename = path.split('/').pop() || '';
    const imageExif = exifData["public" + folder + filename] || {};
    const aspectRatio = imageExif.aspectRatio;
    return {
        src: module.default,
        filename,
        path,
        aspectRatio,
        // Extract date for sorting
        date: imageExif.dateIso
            ? Date.parse(imageExif.dateIso)
            : new Date(0) // fallback to epoch if no date
    }
}));

// Sort images based on sortBy prop
let sortedImages = [...images];
switch (sortBy) {
    case 'date':
    sortedImages.sort((a, b) => b.date - a.date); // newest first
    break;
    case 'filename':
    sortedImages.sort((a, b) => a.filename.localeCompare(b.filename));
    break;
    case 'random':
    sortedImages.sort(() => Math.random() - 0.5);
    break;
}
const displayImages = maxImages ? sortedImages.slice(0, maxImages) : sortedImages;

const getMasonrySizeClass = (index: number, aspectRatio?: number) => {
    // vertical images should always have less horizontal space
    if (aspectRatio && aspectRatio < 1.1) return 'w-1/3';

    if (index === 0 || index % 4 === 0) return 'w-2/3';
    return 'w-1/3';
};

// Get responsive width for preserving aspect ratio
const getImageSize = (layoutType: string, index: number, aspectRatio?: number) => {
    if (layoutType === 'masonry') {
        const isLandscape = aspectRatio && aspectRatio > 1.1;
        if (isLandscape && (index === 0 || index % 4 === 0)) {
            return 1000; // width of two column
        }
        return 500;  // width of one column
    }
    return 500;
};

// Generate unique gallery ID for this instance
const galleryId = `gallery-${Math.random().toString(36).substring(2, 9)}`;
---

<div class={`dynamic-gallery ${galleryId}`} data-layout={layout}>

    {layout === 'masonry' && (
        <!-- Masonry-Mosaic Layout - Smart sizing with minimal white space -->
        <div class="masonry-container">
            <div class="masonry-sizer w-1/3"></div>
            {displayImages.map((image, index) => (
                <div class={`masonry-item ${getMasonrySizeClass(index, image.aspectRatio)} group p-1 overflow-hidden`}>
                    <SquareImage
                        src={image.src}
                        alt={`Photo ${index + 1}`}
                        path={`${folder}${image.filename}`}
                        size={getImageSize(layout, index, image.aspectRatio)}
                    />
                </div>
            ))}
        </div>
    )}

    {layout === 'grid' && (
        <!-- Simple Responsive Grid -->
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2">
                {displayImages.map((image, index) => (
                        <SquareImage
                                src={image.src}
                                alt={`Photo ${index + 1}`}
                                path={`${folder}${image.filename}`}
                                size={getImageSize(layout, index, image.aspectRatio)}
                                square={true}
                        />
                ))}
            </div>
    )}
</div>

{(layout === 'masonry') && (
        <script src="https://unpkg.com/packery@3/dist/packery.pkgd.min.js" />
<script>
    // Initialize Masonry for both masonry layouts
    document.addEventListener('DOMContentLoaded', function() {
        const masonryContainer = document.querySelector('.masonry-container');
        if (masonryContainer) {
            new Packery(masonryContainer, {
                itemSelector: '.masonry-item',
                columnWidth: '.masonry-sizer',
                percentPosition: true,
            });
        }
    });
</script>)}

<style>
/* Grid layout with preserved aspect ratios */
.dynamic-gallery[data-layout="grid"] .grid {
    align-items: start; /* Align items to top */
    }



/* Responsive size adjustments for masonry-mosaic */
@media (max-width: 768px) {
    .dynamic-gallery[data-layout="masonry"] .masonry-item.w-full,
    .dynamic-gallery[data-layout="masonry"] .masonry-item.w-2/3 {
        width: 100% !important; /* Full width on mobile */
    }

    .dynamic-gallery[data-layout="masonry"] .masonry-item.w-1/2 {
        width: 50% !important; /* Half width on mobile */
    }

    .dynamic-gallery[data-layout="masonry"] .masonry-item.w-1/3 {
        width: 50% !important; /* Bigger on mobile */
        }
    }

@media (max-width: 480px) {
    .dynamic-gallery[data-layout="masonry"] .masonry-item {
        width: 100% !important; /* All full width on small mobile */
        }
    }

/* Ensure images in preserved aspect ratio mode look good */
.dynamic-gallery .portfolio-image:not(.aspect-square) {
    display: flex;
    flex-direction: column;
    }

.dynamic-gallery .portfolio-image:not(.aspect-square) > div:first-child {
    flex-grow: 1;
    display: flex;
    align-items: center;
    }

/* Smooth loading animation */
.dynamic-gallery .portfolio-image {
    opacity: 0;
    animation: fadeInUp 0.6s ease forwards;
    }

.dynamic-gallery .portfolio-image:nth-child(1) { animation-delay: 0.1s; }
.dynamic-gallery .portfolio-image:nth-child(2) { animation-delay: 0.2s; }
.dynamic-gallery .portfolio-image:nth-child(3) { animation-delay: 0.3s; }
.dynamic-gallery .portfolio-image:nth-child(4) { animation-delay: 0.4s; }
.dynamic-gallery .portfolio-image:nth-child(5) { animation-delay: 0.5s; }

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
        }
    }
</style>