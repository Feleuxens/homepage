---
import MainLayout from '../layouts/MainLayout.astro';

// Contact information
const contactInfo = {
    email: "me@feleuxens.de",
    phone: "+1 (555) 123-4567",
    location: "Filderstadt",
    availability: "Monday - Friday, 9:00 AM - 5:00 PM"
};

// Service areas
const serviceAreas = [
    "Technology Consulting",
    "System Administration",
    "Software Development",
    "Piano/Trumpet Performances",
    "Arrangement or Transcription",
    "Photography Services"
];
---

<MainLayout title="Contact">
    <!-- Hero Section -->
    <section class="bg-gradient-to-br from-gray-100 to-gray-50 pt-24 pb-8">
        <div class="container">
            <div class="max-w-4xl mx-auto text-center">
                <h1 class="text-4xl md:text-6xl mb-6 opacity-90" id="hero-title">
                    Get In Touch
                </h1>
                <p class="text-xl md:text-2xl text-gray-700 mb-8 opacity-90" id="hero-subtitle">
                    Ready to start your project? Let's discuss how I can help bring your vision to life.
                </p>
            </div>
        </div>
    </section>

    <!--
    Note for me: When the form is implemented, remove all disabled attributed and remove background color
    -->
    <!-- Contact Form & Info Section -->
    <section class="py-12 bg-white">
        <div class="container">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
                <!-- Contact Form -->
                <div class="contact-form">
                    <h2 class="text-3xl mb-8">Send me a message (coming soon...)</h2>
                    <p class="font-serif font-bold mb-8" >For now you have to write me a message via mail.</p>
                    <form class="space-y-6" id="contact-form">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label for="firstName" class="block text-sm font-medium text-gray-700 mb-2">First Name *</label>
                                <input
                                        type="text"
                                        id="firstName"
                                        name="firstName"
                                        required
                                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-gray-200"
                                        placeholder="Max"
                                        disabled
                                />
                            </div>
                            <div>
                                <label for="lastName" class="block text-sm font-medium text-gray-700 mb-2">Last Name *</label>
                                <input
                                        type="text"
                                        id="lastName"
                                        name="lastName"
                                        required
                                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-gray-200"
                                        placeholder="Mustermann"
                                        disabled
                                />
                            </div>
                        </div>

                        <div>
                            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email Address *</label>
                            <input
                                    type="email"
                                    id="email"
                                    name="email"
                                    required
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-gray-200"
                                    placeholder="max@example.de"
                                    disabled
                            />
                        </div>

                        <div>
                            <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">Phone Number</label>
                            <input
                                    type="tel"
                                    id="phone"
                                    name="phone"
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-gray-200"
                                    placeholder="+49 123 456789"
                                    disabled
                            />
                        </div>

                        <div>
                            <label for="service" class="block text-sm font-medium text-gray-700 mb-2">Service Interested In *</label>
                            <select
                                    id="service"
                                    name="service"
                                    required
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-gray-200"
                                    disabled
                            >
                                <option value="">Select a service...</option>
                                <option value="it">DevOps & IT Services</option>
                                <option value="performance">Piano/Trumpet Performance</option>
                                <option value="arrangement">Arrangement or Transcription</option>
                                <option value="photography">Photography</option>
                                <option value="other">Other</option>
                            </select>
                        </div>

                        <div>
                            <label for="eventDate" class="block text-sm font-medium text-gray-700 mb-2">Event/Project Date</label>
                            <input
                                    type="date"
                                    id="eventDate"
                                    name="eventDate"
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors bg-gray-200"
                                    disabled
                            />
                        </div>

                        <div>
                            <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Project Details *</label>
                            <textarea
                                    id="message"
                                    name="message"
                                    rows="5"
                                    required
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition-colors resize-vertical bg-gray-200"
                                    placeholder="Please describe your project, event details, timeline, and any specific requirements..."
                                    disabled
                            ></textarea>
                        </div>

                        <div class="flex items-start">
                            <input
                                    type="checkbox"
                                    id="privacy"
                                    name="privacy"
                                    required
                                    class="mt-1 mr-3 h-4 w-4 text-primary focus:ring-primary border-gray-300 rounded"
                                    disabled
                            />
                            <label for="privacy" class="text-sm text-gray-600">
                                I agree to the <a href="/privacy" class="text-primary hover:underline" target="_blank">privacy policy</a> and consent to being contacted about my inquiry. *
                            </label>
                        </div>

                        <!-- add primary class when activating again -->
                        <button
                                type="submit"
                                class="w-full btn py-4 text-lg font-medium bg-gray-200"
                                id="submit-btn"
                                disabled
                        >
                            Send Message
                        </button>

                        <div id="form-message" class="text-center text-sm hidden"></div>
                    </form>
                </div>

                <!-- Contact Information -->
                <div class="contact-info">
                    <h2 class="text-3xl mb-8">Contact Information</h2>

                    <div class="space-y-6 mb-10">
                        <div class="flex items-start">
                            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mr-4 mt-1">
                                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-semibold text-lg">Email</h3>
                                <p class="text-gray-600">{contactInfo.email}</p>
                                <p class="text-sm text-gray-500">Best for detailed inquiries</p>
                            </div>
                        </div>

                        <!--<div class="flex items-start">
                            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mr-4 mt-1">
                                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-semibold text-lg">Phone</h3>
                                <p class="text-gray-600">{contactInfo.phone}</p>
                                <p class="text-sm text-gray-500">Quick questions & urgent requests</p>
                            </div>
                        </div>-->

                        <div class="flex items-start">
                            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mr-4 mt-1">
                                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-lg">Location</h3>
                                <p class="text-gray-600">{contactInfo.location}</p>
                                <p class="text-sm text-gray-500">Available for regional travel</p>
                            </div>
                        </div>

                        <div class="flex items-start">
                            <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mr-4 mt-1">
                                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-lg">Availability</h3>
                                <p class="text-gray-600">{contactInfo.availability}</p>
                                <p class="text-sm text-gray-500">Response within 24 hours</p>
                            </div>
                        </div>
                    </div>

                    <!-- Services Available -->
                    <div class="bg-gray-50 rounded-lg p-6 mb-8">
                        <h3 class="text-lg mb-4">Services Available</h3>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                            {serviceAreas.map(service => (
                                    <div class="flex items-center">
                                        <svg class="w-4 h-4 mr-2 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                                        </svg>
                                        <span class="text-sm text-gray-700">{service}</span>
                                    </div>
                            ))}
                        </div>
                    </div>

                    <!-- Social Links -->
                    <div>
                        <h3 class="text-lg mb-4">Connect With Me</h3>
                        <div class="flex space-x-4">
                            <a href="https://linkedin.com/in/felixgrueb" target="_blank" class="w-10 h-10 bg-primary text-white rounded-lg flex items-center justify-center hover:bg-primary/80 transition-colors">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                                </svg>
                            </a>
                            <a href="https://github.com/feleuxens" target="_blank" class="w-10 h-10 bg-dark text-white rounded-lg flex items-center justify-center hover:bg-dark/80 transition-colors">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                                </svg>
                            </a>
                            <a href="https://instagram.com/feleuxens" target="_blank" class="w-10 h-10 bg-pink-700 text-white rounded-lg flex items-center justify-center hover:bg-pink-600/80 transition-colors">
                                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Register GSAP plugins
            gsap.registerPlugin(ScrollTrigger);

            // Hero animations
            gsap.to('#hero-title', { opacity: 1, y: 0, duration: 1, ease: 'power3.out' });
            gsap.to('#hero-subtitle', { opacity: 1, y: 0, duration: 1, delay: 0.3, ease: 'power3.out' });

            // Form animations
            gsap.from('.contact-form', {
                scrollTrigger: {
                    trigger: '.contact-form',
                    start: 'top 98%',
                },
                x: -50,
                opacity: 0,
                duration: 0.8,
                ease: 'power2.out'
            });

            gsap.from('.contact-info', {
                scrollTrigger: {
                    trigger: '.contact-info',
                    start: 'top 98%',
                },
                x: 50,
                opacity: 0,
                duration: 0.8,
                ease: 'power2.out'
            });

            gsap.from('.faq-item', {
                scrollTrigger: {
                    trigger: '.faq-item',
                    start: 'top 98%',
                },
                y: 30,
                opacity: 0,
                duration: 0.6,
                stagger: 0.1,
                ease: 'power2.out'
            });
        });

        // Form submission handler
        document.getElementById('contact-form').addEventListener('submit', function(e) {
            e.preventDefault();

            const submitBtn = document.getElementById('submit-btn');
            const messageDiv = document.getElementById('form-message');

            // Show loading state
            submitBtn.disabled = true;
            submitBtn.textContent = 'Sending...';

            // Simulate form submission (replace with actual form handling)
            setTimeout(() => {
                messageDiv.className = 'text-center text-sm text-green-600';
                messageDiv.textContent = 'Thank you! Your message has been sent successfully. I\'ll get back to you within 24 hours.';
                messageDiv.classList.remove('hidden');

                // Reset form
                this.reset();

                // Reset button
                submitBtn.disabled = false;
                submitBtn.textContent = 'Send Message';

                // Hide message after 5 seconds
                setTimeout(() => {
                    messageDiv.classList.add('hidden');
                }, 5000);
            }, 2000);
        });
    </script>
</MainLayout>